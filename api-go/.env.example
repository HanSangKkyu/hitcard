# Backend configuration
# Copy this file to .env and fill in your values

DB_HOST=localhost
DB_PORT=3306
DB_USER=hitcard
DB_PASSWORD=hitcard
DB_NAME=HITCARD
PORT=8080

# HTTPS (optional – set these to enable TLS)
TLS_PORT=8443
TLS_CERT=../certs/cert.pem
TLS_KEY=../certs/key.pem

# Web frontend static serving (optional – served alongside API when set)
WEB_DIR=../app/web-build
